# ── Capno environment variables ─────────────────────────────────────────────
# All variables are OPTIONAL. With none set, Capno runs fully offline:
# realtime sync uses BroadcastChannel (same device, multiple windows/tabs)
# and scenarios/sessions are stored in localStorage.

# ── Supabase (optional): cross-device sync, sign-in, cloud persistence ──────
# Create a project at https://supabase.com, run db/schema.sql in the SQL
# editor, and enable the Email auth provider. Setting these enables:
#   * cross-device realtime vitals sync (session codes work between devices)
#   * institution sign-in at /account (email/password)
#   * cloud storage of custom scenarios and session debriefs for
#     faculty/admin accounts (see docs/DEPLOYMENT.md for role promotion)
# The anon key is safe to expose client-side when RLS is enabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Site URL (optional): absolute URLs for social/search metadata ───────────
# Public origin of this deployment (e.g. https://capno.your-school.edu).
# Enables absolute URLs in Open Graph share metadata, robots.txt, and
# sitemap.xml. Everything works without it — offline labs can ignore this.
NEXT_PUBLIC_SITE_URL=

# ── Managed LLM gateway (optional): pre-configured hosted builds ────────────
# Point the AI features (sim co-pilot, scenario drafting) at an
# OpenAI-compatible gateway operated by your deployment. When BOTH are set
# and Supabase sign-in is configured, signed-in users get AI assistance with
# no API key: requests are authenticated per-request with the user's own
# Supabase session token. These are a URL and a model name, not secrets.
# A key saved on the Settings page always overrides the managed gateway.
# Self-hosted offline labs ignore this — unset means zero AI network calls.
NEXT_PUBLIC_LLM_GATEWAY_URL=
NEXT_PUBLIC_LLM_MODEL=

# ── Faculty access PIN (optional, advisory) ──────────────────────────────────
# A lightweight gate for the faculty controller and editor views in labs that
# do not use Supabase auth. This is NOT a security boundary (it is a public
# client-side value) — it only prevents students from casually opening the
# controller. Signed-in faculty/admin accounts bypass the PIN.
NEXT_PUBLIC_FACULTY_PIN=

# ── Server-only (never NEXT_PUBLIC_): used by future server features ─────────
# SUPABASE_SERVICE_ROLE_KEY=
